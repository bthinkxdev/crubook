[Unit]
Description=author.thinks (crubook) Django app
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/crubook
EnvironmentFile=-/opt/crubook/.env
Environment=DJANGO_DEBUG=0
ExecStart=/opt/crubook/venv/bin/gunicorn config.wsgi:application --bind 127.0.0.1:8002 --workers 2
Restart=on-failure

[Install]
WantedBy=multi-user.target
